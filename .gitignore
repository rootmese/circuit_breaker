# .gitignore for a .NET solution

# -------------------------
# Build output
# -------------------------
**/bin/
**/obj/

# -------------------------
# NuGet
# -------------------------
*.nupkg
*.snupkg
local-packages/
/dist/
/nupkg/
# Restore state
*.lock.json
!packages.lock.json

# -------------------------
# IDE — Visual Studio
# -------------------------
*.user
*.userosscache
*.suo
*.sln.docstates
.vs/
*.rsuser

# -------------------------
# IDE — VS Code
# -------------------------
.vscode/

# -------------------------
# IDE — JetBrains Rider / ReSharper
# -------------------------
.idea/
*.sln.iml
*.DotSettings.user
/.resharper
_ReSharper*/
*.ReSharper

# -------------------------
# Test & Coverage
# -------------------------
/TestResults/
**/TestResults/
coverage*/
*.coveragexml
*.cobertura.xml
*.opencover.xml

# -------------------------
# Benchmarks
# -------------------------
BenchmarkDotNet.Artifacts/

# -------------------------
# Publish
# -------------------------
/publish/
**/publish/

# -------------------------
# Logs & temporaries
# -------------------------
*.log
*.tmp
*.temp
*.bak
*.cache

# -------------------------
# .NET tools & global packages
# -------------------------
/.dotnet
/.nuget
.tool-versions

# -------------------------
# Environment & secrets
# -------------------------
appsettings.Development.json
appsettings.Local.json
*.env
.env
secrets.json

# -------------------------
# OS artifacts
# -------------------------
.DS_Store
Thumbs.db
desktop.ini

# -------------------------
# Generated files
# -------------------------
Generated/**
*.g.cs
*.generated.cs

# -------------------------
# Source Link / XML docs (keep .xml in output, ignore loose ones)
# -------------------------
*.sourcelink.json
