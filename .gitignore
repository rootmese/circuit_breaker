# .gitignore for a .NET solution
# Build output
**/bin/
**/obj/
local-packages/

# User-specific files
*.user
*.userosscache
*.suo
*.sln.docstates
# VS / Rider / VSCode settings
.vscode/
.vscode/**
.vs/
.idea/
# NuGet packages
*.nupkg
# Publish folder
/publish/
# Temporary files
*.log
*.tmp
# Test results
/TestResults/
# ReSharper
*.DotSettings.user
# Resharper cache
/.resharper
# JetBrains Rider
*.sln.iml
# Coverage reports
coverage*
# Dotnet tools folder
/.dotnet
# Global packages folder
/.nuget
# Configuration files
appsettings.Development.json
# Generated files
Generated/**
# Dist folder
/dist/
# Nupkg folder
/nupkg/
# Benchmark artifacts
BenchmarkDotNet.Artifacts/
